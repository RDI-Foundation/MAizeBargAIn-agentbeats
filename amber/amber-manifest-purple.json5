{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/gsmithline/llm-negotiator-purple:latest",
    entrypoint: [
      "python",
      "main.py",
      "--host", 
      "0.0.0.0", 
      "--port", 
      "8080"
    ],
    env: {
      ANTHROPIC_API_KEY: "${config.anthropic_api_key}",
      ANTHROPIC_MODEL: "${config.anthropic_model}",
      LOG_LEVEL: "INFO"
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8080 }
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      anthropic_api_key: { type: "string", secret: true },
      anthropic_model: { type: "string" }
    },
    required: ["anthropic_api_key", "anthropic_model"],
    additionalProperties: false
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" }
  },
  exports: {
    a2a: "a2a"
  },
}
